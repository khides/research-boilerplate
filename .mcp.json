{
  "mcpServers": {
    "serena": {
      "type": "sse",
      "url": "http://127.0.0.1:9121/sse"
    },
    "notion": {
      "command": "npx",
      "args": ["-y", "@notionhq/notion-mcp-server"],
      "env": {
        "OPENAPI_MCP_HEADERS": "{\"Authorization\": \"Bearer ${NOTION_API_KEY}\", \"Notion-Version\": \"2022-06-28\"}"
      }
    },
    "slack": {
      "command": "npx",
      "args": ["-y", "@anthropic/slack-mcp-server"],
      "env": {
        "SLACK_BOT_TOKEN": "${SLACK_BOT_TOKEN}"
      }
    },
    "google-scholar": {
      "command": "npx",
      "args": ["-y", "google-scholar-mcp-server"]
    },
    "arxiv": {
      "command": "npx",
      "args": ["-y", "arxiv-mcp-server"]
    },
    "filesystem": {
      "command": "npx",
      "args": ["-y", "@anthropic/filesystem-mcp-server", "./out", "./data", "./docs"]
    },
    "syntopic": {
      "type": "http",
      "url": "https://mcp.syntopic.dev/mcp"
    }

  }
}
